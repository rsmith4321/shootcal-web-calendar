{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "shootcal-web-calendar/calendar",
	"version": "1.0.0",
	"title": "ShootCal Web Calendar",
	"category": "widgets",
	"icon": "calendar-alt",
	"description": "Show an iCal calendar as a month grid - free/busy availability or a full calendar with event titles and times. Paste the feed URL right in the block.",
	"keywords": [ "calendar", "availability", "booking", "photographer", "shootcal" ],
	"textdomain": "shootcal-web-calendar",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"margin": [ "top", "bottom" ]
		}
	},
	"attributes": {
		"months": {
			"type": "number"
		},
		"timezone": {
			"type": "string",
			"default": ""
		},
		"firstDay": {
			"type": "number"
		},
		"mode": {
			"type": "string",
			"default": "availability"
		},
		"url": {
			"type": "string",
			"default": ""
		},
		"multiSessionDay": {
			"type": "boolean",
			"default": true
		}
	},
	"editorScript": "shootcal-web-calendar-block-editor"
}
